# ── Required — Bedrock API key (Bearer token auth, no IAM needed for Bedrock)
# Generate from: AWS Console → Amazon Bedrock → API keys
BEDROCK_API_KEY=

# Cross-region inference profile ID for Claude Sonnet 4.6 (required)
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# AWS region where Bedrock is enabled
AWS_REGION=us-east-1

# ── Required for Amazon Polly TTS (IAM credentials)
# Minimal IAM policy needed: polly:SynthesizeSpeech only
# If left blank, frontend falls back to browser Web Speech API automatically
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Optional — S3 frame archiving (requires s3:PutObject + s3:DeleteObject)
# Leave blank to skip S3 archiving (Polly audio is never stored in S3)
S3_BUCKET_NAME=

# ── Note: Amazon Transcribe is NOT used in this codebase.
# ── STT is handled by the browser SpeechRecognition API (zero latency, free).
# ── Only Polly requires IAM credentials.
