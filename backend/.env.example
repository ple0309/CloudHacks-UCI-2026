# Bedrock API key (from AWS Console → Bedrock → API keys)
# This is the primary credential — no IAM keys required for Bedrock calls
BEDROCK_API_KEY=

# AWS region where Bedrock is enabled
AWS_REGION=us-east-1

# Bedrock model ID
# Use the cross-region inference profile prefix (us. / eu. / au.) — required for Claude 4.x
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# S3 archiving (optional) — only needed if you want frame backups
# Requires IAM credentials with s3:PutObject and s3:DeleteObject on this bucket
S3_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
